# PostgreSQL connection string (provided by EasyPanel Postgres service)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quiz?schema=public"

# Redis connection string (provided by EasyPanel Redis service). Optional in dev:
# if unreachable the app degrades gracefully and relies on DB constraints.
REDIS_URL="redis://localhost:6379"

# Secret used to sign JWT session tokens. Generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-string-please"

# Canonical public URL of the application
NEXTAUTH_URL="http://localhost:3000"
